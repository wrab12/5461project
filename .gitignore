# Exclude large generated files (can be regenerated by running analysis scripts)
datasets/Real_Data_with_CCC_clustering.h5ad
datasets/Real_Data_Improved_Clustering.h5ad

# Python cache
__pycache__/
*.pyc

# Jupyter notebooks
*.ipynb
*.ipynb_checkpoints/

# Data files in root directory
/*.h5ad
/*.png

# Translation scripts
translate*.py
translate.sed

# Chinese documentation
*.md
!README.md
!docs/*.md

# Other files
.claude/
data/
cleanup_old_files.sh
commot.pdf
CSCI*.pdf

# Root level scripts (keep only scripts/ directory)
/*.py
!requirements.txt
